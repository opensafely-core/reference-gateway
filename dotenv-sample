# The GitHub organisation containing researchers' code
GITHUB_ORG=opensafely-demo

# The identifier of the OpenSAFELY backend
OPENSAFELY_BACKEND=test

# The URL of the RAP Controller
RAP_CONTROLLER_URL=http://localhost:3000/controller/v1

# The token shared with the RAP Controller
RAP_CONTROLLER_TOKEN=rap_token

# The token shared with Airlock
AIRLOCK_TOKEN=airlock_token

# The token used to query GitHub
GITHUB_TOKEN=CHANGEME

# The credentials for a GitHub OAuth app
GITHUB_OAUTH_CLIENT_ID=CHANGEME
GITHUB_OAUTH_CLIENT_SECRET=CHANGEME

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-key-no-not-use-in-prod
